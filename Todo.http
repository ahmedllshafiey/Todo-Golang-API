### ================= VARIABLES =================
@BASE_URL = http://localhost:3000
@TEST_EMAIL = test@example.com
@TEST_PASSWORD = 123456
@INVALID_PASSWORD = wrongpassword
@NON_EXIST_EMAIL = nouser@example.com
@TODO_ID = 1
@NON_EXIST_TODO = 9999

### ================= HEALTH CHECK =================
GET {{BASE_URL}}/

### ================= AUTH =================

# Register valid user
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

###

# Register user with short password (fail)
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "email": "test2@example.com",
  "password": "123"
}

###

# Register user with missing email (fail)
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "password": "{{TEST_PASSWORD}}"
}

###

# Register user with duplicate email (fail)
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

###

# Login valid user
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

###

# Login with wrong password (fail)
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{INVALID_PASSWORD}}"
}

###

# Login non-existing user (fail)
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "{{NON_EXIST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

###

# Login with missing fields (fail)
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}"
}

### ================= PROTECTED =================

# Access protected route (replace token)
GET {{BASE_URL}}/protected-test
Authorization: Bearer YOUR_TOKEN_HERE

### ================= TODOS =================

# Get all todos
GET {{BASE_URL}}/todos
Authorization: Bearer YOUR_TOKEN_HERE

###

# Create todos
POST {{BASE_URL}}/todos
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Learn Go",
  "completed": false
}

###

POST {{BASE_URL}}/todos
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Write API",
  "completed": false
}

###

# Create todo with missing title (fail)
POST {{BASE_URL}}/todos
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "completed": true
}

###

# Get todo by ID
GET {{BASE_URL}}/todos/{{TODO_ID}}
Authorization: Bearer YOUR_TOKEN_HERE

###

# Get todo invalid ID / non-existing
GET {{BASE_URL}}/todos/abc
Authorization: Bearer YOUR_TOKEN_HERE

###

GET {{BASE_URL}}/todos/{{NON_EXIST_TODO}}
Authorization: Bearer YOUR_TOKEN_HERE

###

# Update todos
PUT {{BASE_URL}}/todos/{{TODO_ID}}
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Updated Title Only"
}

###

PUT {{BASE_URL}}/todos/{{TODO_ID}}
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "completed": true
}

###

PUT {{BASE_URL}}/todos/{{TODO_ID}}
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Fully Updated",
  "completed": true
}

###

# Update with empty body / invalid ID / non-existing
PUT {{BASE_URL}}/todos/{{TODO_ID}}
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{}

###

PUT {{BASE_URL}}/todos/abc
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Fail case"
}

###

PUT {{BASE_URL}}/todos/{{NON_EXIST_TODO}}
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "title": "Does not exist"
}

###

# Delete todos
DELETE {{BASE_URL}}/todos/7
Authorization: Bearer YOUR_TOKEN_HERE

###

DELETE {{BASE_URL}}/todos/abc
Authorization: Bearer YOUR_TOKEN_HERE

###

DELETE {{BASE_URL}}/todos/{{NON_EXIST_TODO}}
Authorization: Bearer YOUR_TOKEN_HERE
